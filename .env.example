# Database (Docker Internal)
DATABASE_URL="postgresql://jcaesar_user:jcaesar_password@db:5432/jcaesar_db"

# Clerk Authentication (Get these from Clerk Dashboard)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
CLERK_WEBHOOK_SECRET=whsec_...

# AI Engines
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
FIRECRAWL_API_KEY=fc-...

# Stripe (Ödeme Sistemleri)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Redis (Docker Internal)
REDIS_URL="redis://redis:6379"

# App
NEXT_PUBLIC_APP_URL=https://sizin-alan-adiniz.com
APP_SECRET=rastgele-uzun-bir-string

# Admin — Clerk user ID'lerini virgülle ayır
ADMIN_CLERK_IDS=user_xxxx,user_yyyy

# Channels (Meta, etc.)
META_VERIFY_TOKEN=kendi-uydurdugunuz-uzun-bir-token
META_WEBHOOK_VERIFY_TOKEN=kendi-uydurdugunuz-uzun-bir-token
META_APP_SECRET=your_meta_app_secret
# Bird API
BIRD_API_KEY=your_bird_api_key
BIRD_WORKSPACE_ID=your_bird_workspace_id
# SendGrid
SENDGRID_API_KEY=SG.your_key
EMAIL_FROM=noreply@jcaesars.com

# Meta / Instagram OAuth
META_APP_ID=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# Slack
SLACK_SIGNING_SECRET=

# SMTP (Email)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Health Check
HEALTH_CHECK_TOKEN=your-secret-health-token

# Node
NODE_ENV=production

# ── FAZ 3: Production Infrastructure ─────────────────────────────────────────

# Prisma Connection Pool Tuning (PgBouncer uyumlu)
# PgBouncer max 1000 bağlantıyı yönetir; Prisma per-instance limit düşük tutulmalı
PRISMA_CONNECTION_LIMIT=10
PRISMA_POOL_TIMEOUT=10

# BullMQ Tenant Fairness
# Bir chatbot'un dakikada işleyebileceği maksimum kanal mesajı
CHANNEL_RATE_LIMIT=30

# Sentry Error Tracking (https://sentry.io)
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_AUTH_TOKEN=

# Cohere Re-ranking (FAZ 2 — RAG kalite katmanı)
# Yoksa vector search sonuçları sırasına göre fallback yapılır
COHERE_API_KEY=

# Prometheus Metrics API Token (boş bırakılırsa herkese açık)
METRICS_TOKEN=your-secret-metrics-token

# OpenTelemetry (opsiyonel — Grafana Tempo / Jaeger endpoint)
OTEL_SERVICE_NAME=jcaesar-agent
OTEL_EXPORTER_OTLP_ENDPOINT=
