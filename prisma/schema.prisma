generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String         @id @default(cuid())
  clerkId            String         @unique
  email              String         @unique
  name               String?
  avatar             String?
  role               UserRole       @default(USER)
  stripeCustomerId   String?
  organizationId     String?
  conversationAlerts Boolean        @default(true)
  botHealthChecks    Boolean        @default(true)
  platformUpdates    Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  chatbots           Chatbot[]
  conversations      Conversation[]
  notifications      Notification[]
  subscriptions      Subscription[]
  teamMemberships    TeamMember[]
  tokenUsages        TokenUsage[]
  organization       Organization?  @relation(fields: [organizationId], references: [id])
}

model Organization {
  id                   String       @id @default(cuid())
  name                 String
  slug                 String       @unique
  planId               String
  messageLimitOverride Int?
  tokenLimitOverride   Int?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  chatbots             Chatbot[]
  plan                 Plan         @relation(fields: [planId], references: [id])
  teamMembers          TeamMember[]
  users                User[]
}

model TeamMember {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           TeamRole     @default(MEMBER)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@unique([userId, organizationId])
}

model Plan {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  description   String?
  priceMonthly  Int
  priceYearly   Int
  messageLimit  Int
  chatbotLimit  Int
  tokenLimit    Int
  extraBotPrice Float          @default(0)
  crawlLimit    Int            @default(3)
  features      Json
  isPopular     Boolean        @default(false)
  isEnterprise  Boolean        @default(false)
  stripePriceId String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  organizations Organization[]
  subscriptions Subscription[]
  coupons       Coupon[]
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  planId               String
  status               SubscriptionStatus
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  plan                 Plan               @relation(fields: [planId], references: [id])
  user                 User               @relation(fields: [userId], references: [id])
}

model Chatbot {
  id                       String              @id @default(cuid())
  name                     String
  slug                     String              @unique
  description              String?
  userId                   String
  organizationId           String?
  model                    String              @default("gpt-4o")
  temperature              Float               @default(0.7)
  maxTokens                Int                 @default(1000)
  businessContext          String?
  systemPrompt             String              @default("You are a helpful assistant.")
  welcomeMessage           String              @default("Hi! How can I help you today?")
  placeholderText          String              @default("Bir mesaj yazın...")
  primaryColor             String              @default("#e25b31")
  position                 String              @default("bottom-right")
  showBranding             Boolean             @default(true)
  avatar                   String?
  language                 String              @default("tr")
  widgetMode               WidgetMode          @default(FLOAT)
  collectLeads             Boolean             @default(false)
  handoffEnabled           Boolean             @default(true)
  status                   ChatbotStatus       @default(DRAFT)
  isPublic                 Boolean             @default(false)
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
  assistantMessageColor    String              @default("#f4f4f5")
  borderRadius             String              @default("16px")
  fontFamily               String              @default("Inter, sans-serif")
  fontSize                 String              @default("14px")
  userMessageColor         String              @default("#18181b")
  widgetShadow             String              @default("0 20px 40px -8px rgba(0,0,0,0.15)")
  appointmentReminderHours Int                 @default(24)
  appointmentReminderMsg   String?             @default("Merhaba {name}, {time} saatindeki randevunuzu hatırlatmak isteriz.")
  appointments             Appointment[]
  channels                 Channel[]
  organization             Organization?       @relation(fields: [organizationId], references: [id])
  user                     User                @relation(fields: [userId], references: [id])
  conversations            Conversation[]
  crmContacts              CrmContact[]
  dataSources              DataSource[]
  knowledgeSources         KnowledgeSource[]
  suggestedQuestions       SuggestedQuestion[]
  tokenUsages              TokenUsage[]
  messageTemplates         MessageTemplate[]
  webhookEndpoints         WebhookEndpoint[]
}

model SuggestedQuestion {
  id        String   @id @default(cuid())
  chatbotId String
  question  String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chatbot   Chatbot  @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
}

model DataSource {
  id            String           @id @default(cuid())
  chatbotId     String
  type          DataSourceType
  name          String
  url           String?
  status        DataSourceStatus @default(PENDING)
  fileUrl       String?
  fileType      String?
  fileSize      Int?
  crawlDepth    Int              @default(3)
  crawlStatus   String?
  pagesCount    Int              @default(0)
  crawlSchedule String?
  lastCrawledAt DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  settings      Json?
  chatbot       Chatbot          @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  urls          DataSourceUrl[]
  documents     Document[]
}

model DataSourceUrl {
  id            String           @id @default(cuid())
  dataSourceId  String
  url           String
  title         String?
  charCount     Int?
  status        DataSourceStatus @default(PENDING)
  errorMessage  String?
  lastCrawledAt DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  dataSource    DataSource       @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)

  @@unique([dataSourceId, url])
  @@index([dataSourceId])
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model Document {
  id                String                 @id @default(cuid())
  dataSourceId      String?
  content           String
  url               String?
  title             String?
  metadata          Json?
  embedding         Unsupported("vector(1536)")?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  knowledgeSourceId String?
  dataSource        DataSource?            @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)
  knowledgeSource   KnowledgeSource?       @relation(fields: [knowledgeSourceId], references: [id], onDelete: Cascade)

  @@index([dataSourceId])
  @@index([knowledgeSourceId])
}

model Conversation {
  id                 String             @id @default(cuid())
  chatbotId          String
  userId             String?
  channel            String             @default("widget")
  channelUserId      String?
  status             ConversationStatus @default(ACTIVE)
  assignedTo         String?
  aiEnabled          Boolean            @default(true)
  ipAddress          String?
  userAgent          String?
  country            String?
  tags               Json?
  contactName        String?
  contactEmail       String?
  contactPhone       String?
  contactProfilePic  String?
  contactNotes       String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  sentiment          String?
  chatbot       Chatbot            @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  user          User?              @relation(fields: [userId], references: [id])
  notes         ConversationNote[]
  messages      Message[]
  tokenUsages   TokenUsage[]

  @@index([chatbotId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model ConversationNote {
  id             String       @id @default(cuid())
  conversationId String
  content        String
  createdBy      String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Message {
  id               String       @id @default(cuid())
  conversationId   String
  role             MessageRole
  content          String
  model            String?
  tokensUsed       Int          @default(0)
  promptTokens     Int          @default(0)
  completionTokens Int          @default(0)
  sources          Json?
  rating           Int?
  feedback         String?
  agentId          String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  conversation     Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
}

model Channel {
  id            String        @id @default(cuid())
  chatbotId     String
  type          ChannelType
  name          String
  config        Json
  status        ChannelStatus @default(DISCONNECTED)
  webhookUrl    String?
  phoneNumberId String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  chatbot       Chatbot       @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  @@index([chatbotId])
  @@index([type])
}

model TokenUsage {
  id               String        @id @default(cuid())
  userId           String
  chatbotId        String?
  conversationId   String?
  model            String
  tokensUsed       Int
  promptTokens     Int
  completionTokens Int
  cost             Float
  createdAt        DateTime      @default(now())
  chatbot          Chatbot?      @relation(fields: [chatbotId], references: [id])
  conversation     Conversation? @relation(fields: [conversationId], references: [id])
  user             User          @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([model])
}

model AIAction {
  id        String     @id @default(cuid())
  chatbotId String
  name      String
  type      ActionType
  config    Json
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model AdminSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  encrypted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApiKey {
  id         String    @id @default(cuid())
  name       String
  key        String
  provider   String
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model KnowledgeSource {
  id        String     @id @default(cuid())
  chatbotId String
  type      String
  name      String
  url       String?
  fileUrl   String?
  content   String?
  status    String     @default("PENDING")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  documents Document[]
  chatbot   Chatbot    @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  userEmail  String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([entityType])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  link      String?
  read      Boolean  @default(false)
  type      String   @default("INFO")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String
  phone     String?
  message   String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model CrmContact {
  id            String        @id @default(cuid())
  chatbotId     String
  name          String?
  email         String?
  phone         String?
  notes         String?
  status        String        @default("NEW")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  externalId    String?
  sourceChannel String        @default("WIDGET")
  profilePic    String?
  appointments  Appointment[]
  chatbot       Chatbot       @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  @@index([chatbotId])
  @@index([externalId])
}

model Appointment {
  id            String      @id @default(cuid())
  chatbotId     String
  contactId     String?
  staffId       String?
  title         String
  description   String?
  startTime     DateTime
  endTime       DateTime
  status        String      @default("SCHEDULED")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  currency      String      @default("TRY")
  paymentStatus String      @default("UNPAID")
  price         Float?      @default(0)
  reminderSent  Boolean     @default(false)
  cancelToken   String?     @unique
  gcalEventId   String?
  chatbot       Chatbot     @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  contact       CrmContact? @relation(fields: [contactId], references: [id])
  staff         Staff?      @relation(fields: [staffId], references: [id])

  @@index([chatbotId])
  @@index([contactId])
  @@index([staffId])
}

enum UserRole {
  USER
  ADMIN
  SUPERADMIN
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum SubscriptionStatus {
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  PAUSED
}

enum WidgetMode {
  FLOAT
  POPUP
  INLINE
}

enum ChatbotStatus {
  DRAFT
  TRAINING
  ACTIVE
  PAUSED
  ERROR
}

enum DataSourceType {
  WEBSITE
  FILE
  TEXT
  API
  NOTION
  QNA
}

enum DataSourceStatus {
  PENDING
  CRAWLING
  PROCESSING
  COMPLETED
  ERROR
}

enum ConversationStatus {
  ACTIVE
  CLOSED
  ESCALATED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum ChannelType {
  WIDGET
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  SLACK
  TELEGRAM
  EMAIL
  API
  ZAPIER
  SHOPIFY
  WOOCOMMERCE
  GOOGLE_CALENDAR
}

enum ChannelStatus {
  CONNECTED
  DISCONNECTED
  ERROR
  PENDING
}

enum ActionType {
  CALENDLY
  STRIPE_PAYMENT
  ZENDESK_TICKET
  WEBHOOK
  FORM
  LEAD_CAPTURE
  GOOGLE_CALENDAR
}

model Coupon {
  id              String   @id @default(cuid())
  code            String   @unique
  planId          String
  durationDays    Int      @default(14)
  maxUses         Int      @default(100)
  usedCount       Int      @default(0)
  isActive        Boolean  @default(true)
  discountPercent Int?     // Percentage off, e.g. 20 for 20%
  stripeCouponId  String?  // Linked stripe coupon id
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  plan            Plan     @relation(fields: [planId], references: [id])
}

model Staff {
  id           String        @id @default(cuid())
  name         String
  email        String?
  avatar       String?
  role         String        @default("STAFF")
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
}

model ScheduleSetting {
  id           String   @id @default(cuid())
  chatbotId    String   @unique
  workingDays  String   @default("1,2,3,4,5") // Mon-Fri (1-5)
  startHour    String   @default("09:00")
  endHour      String   @default("18:00")
  slotDuration Int      @default(30) // in minutes
  staffCapacity Int     @default(3)  // standard max staff available per slot
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model MessageTemplate {
  id              String   @id @default(cuid())
  chatbotId       String
  name            String
  category        String?
  language        String?  @default("en_US")
  status          String   @default("PENDING") // APPROVED, REJECTED, PENDING
  components      Json?    // The JSON definition of the template (headers, body, buttons)
  metaTemplateId  String?  @unique // Meta's internal ID for the template
  rejectionReason String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  chatbot         Chatbot  @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  @@index([chatbotId])
  @@index([status])
}

model WebhookEndpoint {
  id        String   @id @default(cuid())
  chatbotId String
  url       String
  secret    String
  events    String[] // ["conversation.created", "conversation.updated", "lead.created", "message.received"]
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  chatbot   Chatbot  @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  @@index([chatbotId])
}
